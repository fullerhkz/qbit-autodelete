# qbit-autodelete — configuracao central
# Copie para /etc/qbit-autodelete.env, ajuste e proteja com chmod 640.

# Conexao (nao coloque credenciais no script ou no repositorio)
QBT_URL="http://QBT_HOST:QBT_PORT"
QBT_USER="QBT_USERNAME"
QBT_PASS="QBT_PASSWORD"

# Regras ficam em arquivo simples: Categoria|horas|min_ratio
CATEGORY_RULES_FILE="/PATH/TO/qbit-autodelete.categories"
INCLUDE_NO_CATEGORY="false"
NO_CATEGORY_RETENTION_HOURS="168"
DEFAULT_MIN_RATIO="1.0"              # terceiro campo opcional nas regras substitui este valor
RATIO_PROTECTION_MAX_HOURS="336"     # libera abaixo do ratio apos 14 dias; 0 = protege indefinidamente

# Comece sempre simulando. Troque para false somente depois de revisar os logs.
DRY_RUN="true"
LOG_LEVEL="summary"               # summary ou detailed
DELETE_FILES="true"               # false remove so do qBittorrent
ALLOW_INCOMPLETE_DELETE="false"    # recomendado: nunca habilitar
PROTECTED_TAGS="keep,never-delete"
SKIP_FORCE_STARTED="true"
SKIP_ACTIVE_TRANSFERS="true"
MIN_INACTIVE_HOURS="6"

# Limpeza normal: prioriza baixo retorno de upload por espaco ocupado.
NORMAL_CLEANUP_ENABLED="true"
NORMAL_MIN_SCORE="70"               # conservador: remove apenas baixa produtividade clara

# Limpeza agressiva: aceita pontuacoes menores quando faltar espaco.
AGGRESSIVE_MIN_SCORE="35"
AGGRESSIVE_WITHOUT_HISTORY="false"   # racing: nunca decide sem medir upload recente
MAX_DELETE_PER_RUN="15"              # reduz rajadas de metadados nos HDDs
MAX_RECLAIM_GB_PER_RUN="400"         # 0 = sem limite por tamanho estimado

# Pontuacao de exclusao = 100. Pesos devem somar 100.
# Baixa eficiencia tem o maior peso para maximizar upload por GiB armazenado.
SCORE_LOW_UPLOAD_WEIGHT="45"
SCORE_SIZE_WEIGHT="20"
SCORE_INACTIVITY_WEIGHT="20"
SCORE_COMPETITION_WEIGHT="15"      # muitos seeds para poucos leechers = mais descartavel
UPLOAD_EFFICIENCY_FULL_MIB_PER_GIB_DAY="100"
SIZE_FULL_SCORE_GB="100"
INACTIVITY_FULL_SCORE_HOURS="168"

# Historico persistente. O systemd cria este diretorio com StateDirectory=.
STATE_FILE="/PATH/TO/STATE/state.json"
LOCK_FILE="/PATH/TO/STATE/run.lock"
HISTORY_MIN_SAMPLES="6"
HISTORY_MIN_HOURS="6"
HISTORY_MIN_SAMPLE_SECONDS="1800"
UPLOAD_EWMA_ALPHA_PERCENT="35"      # peso da amostra mais recente na media movel

# Pressao de disco. O gatilho efetivo usa o MAIOR entre GB e percentual.
# Para um volume RAID0 grande, aponte STORAGE_PATH para o mount agregado e use percentuais.
DISK_PRESSURE_ENABLED="true"
STORAGE_PATH="/PATH/TO/TORRENT/STORAGE"
LOW_WATERMARK_GB="0"               # 0 desabilita o criterio absoluto
HIGH_WATERMARK_GB="0"
LOW_WATERMARK_PERCENT="10"         # abaixo de 10%: modo agressivo
HIGH_WATERMARK_PERCENT="15"        # tenta voltar a 15%

# Rede e execucao
CURL_INSECURE="false"
CONNECT_TIMEOUT="10"
REQUEST_TIMEOUT="60"
LOGIN_RETRIES="5"
